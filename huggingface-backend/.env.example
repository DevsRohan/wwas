# ============================================================
# WWAS WhatsApp Engine - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Server Configuration
PORT=7860
NODE_ENV=production

# API Security - Generate a strong random string (min 32 chars)
API_KEY=your_strong_api_key_here_minimum_32_characters

# Webhook Configuration
# URL of your Hostinger webhook endpoint
WEBHOOK_URL=https://yourdomain.com/webhook.php

# HMAC secret for webhook signature verification (must match PHP config)
WEBHOOK_SECRET=your_hmac_secret_here_minimum_32_characters

# Webhook retry configuration
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=2000

# WhatsApp Session
# Directory for LocalAuth session storage
WA_SESSION_DIR=/app/wa_session
WA_CLIENT_ID=wwas-client

# Puppeteer Configuration
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# Set to true on Hugging Face / headless environments
PUPPETEER_HEADLESS=true

# Rate Limiting
# Max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# CORS - Comma-separated list of allowed origins
# Set to your Hostinger domain
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=info
